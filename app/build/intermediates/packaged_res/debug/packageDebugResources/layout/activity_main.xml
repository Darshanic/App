<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_dark"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top Info -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trip 1: ಮಂಡ್ಯ to ಶ್ರೀರಂಗಪಟ್ಟಣ"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp"/>

    <!-- From / To section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FROM"
            android:backgroundTint="#333333"
            android:textColor="@color/white"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text=" ಮಂಡ್ಯ"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="8dp">
        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TO"
            android:backgroundTint="#333333"
            android:textColor="@color/white"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text=" ಇಂದುವಾಳು"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"/>
    </LinearLayout>

    <!-- Quick select grid (dummy for visual match) -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">
        <Button android:text="ಕಲ್ಲಹಳ್ಳಿ" android:backgroundTint="#333" android:textColor="@color/white" android:layout_margin="4dp" android:layout_columnWeight="1"/>
        <Button android:text="ಇಂದುವಾಳು" android:backgroundTint="@color/accent_blue" android:textColor="@color/white" android:layout_margin="4dp" android:layout_columnWeight="1"/>
        <Button android:text="ಸುಂಡಳ್ಳಿ" android:backgroundTint="#333" android:textColor="@color/white" android:layout_margin="4dp" android:layout_columnWeight="1"/>
    </GridLayout>

    <!-- Spacer -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Passenger Counters -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="8dp">
        <Button android:id="@+id/btnAdultMinus" android:text="-" android:backgroundTint="#333" android:layout_weight="1" android:layout_width="0dp"/>
        <TextView android:id="@+id/tvAdultCount" android:text="Adult: 1" android:textColor="@color/white" android:textSize="18sp" android:layout_weight="2" android:layout_width="0dp" android:gravity="center"/>
        <Button android:id="@+id/btnAdultPlus" android:text="+" android:backgroundTint="#333" android:layout_weight="1" android:layout_width="0dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="16dp">
        <Button android:id="@+id/btnChildMinus" android:text="-" android:backgroundTint="#333" android:layout_weight="1" android:layout_width="0dp"/>
        <TextView android:id="@+id/tvChildCount" android:text="Child: 0" android:textColor="@color/white" android:textSize="18sp" android:layout_weight="2" android:layout_width="0dp" android:gravity="center"/>
        <Button android:id="@+id/btnChildPlus" android:text="+" android:backgroundTint="#333" android:layout_weight="1" android:layout_width="0dp"/>
    </LinearLayout>

    <!-- Bottom Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal">
        <Button android:text="PASS" android:backgroundTint="#333" android:layout_weight="1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnPrint" android:text="PRINT" android:backgroundTint="#222" android:textColor="@color/white" android:textSize="24sp" android:layout_weight="2" android:layout_width="0dp" android:layout_height="match_parent"/>
        <Button android:text="RESET" android:backgroundTint="#333" android:layout_weight="1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginStart="8dp"/>
    </LinearLayout>
    
</LinearLayout>
