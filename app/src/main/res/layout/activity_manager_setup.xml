<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_manager_setup"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="14dp"
            android:text="@string/manager_choose_auth"
            android:textSize="14sp" />

        <RadioGroup
            android:id="@+id/rgAuthMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbPassKey"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/manager_pass_key" />

            <RadioButton
                android:id="@+id/rbBiometric"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/manager_biometric" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/manager_login_passkey"
            android:id="@+id/tvPassKeyLabel" />

        <EditText
            android:id="@+id/etPassKeyInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/manager_hint_passkey"
            android:inputType="numberPassword" />

        <Button
            android:id="@+id/btnAuthorizePassKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/manager_authorize_controls" />

        <Button
            android:id="@+id/btnBiometric"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/manager_authorize_biometric"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvAdminStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/manager_admin_locked"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/manager_zones" />

        <Spinner
            android:id="@+id/spZone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/manager_division" />

        <Spinner
            android:id="@+id/spDivision"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnConfirmAdminScope"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/manager_confirm_scope" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/manager_select_route" />

        <Spinner
            android:id="@+id/spRoute"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/manager_auto_up_route" />

                <TextView
                    android:id="@+id/tvUpRoute"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/section_background"
                    android:padding="10dp"
                    android:text="-" />
            </LinearLayout>

            <Space
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/manager_auto_down_route" />

                <TextView
                    android:id="@+id/tvDownRoute"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/section_background"
                    android:padding="10dp"
                    android:text="-" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/manager_bus_numbers" />

        <EditText
            android:id="@+id/etBusNumbers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/manager_bus_numbers_hint"
            android:inputType="text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/manager_bus_type" />

        <TextView
            android:id="@+id/tvBusType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/section_background"
            android:padding="10dp"
            android:text="-" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchConfirmBeforePrint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/manager_confirm_print" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnResetSetup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/manager_reset" />

            <Button
                android:id="@+id/btnSaveSetup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/manager_save_setup" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
