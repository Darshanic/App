<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp"
        android:gravity="center"
        android:text="Commute Management"
        android:textColor="@color/home_title_text"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="Home Dashboard"
        android:textColor="@color/home_subtitle_text"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnManagerSetup"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/home_btn_setup"
        android:text="Manager Setup"
        android:textAllCaps="false"
        android:textColor="@color/home_title_text"
        android:textSize="20sp" />

    <Button
        android:id="@+id/btnCommuteTicket"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/home_btn_ticket"
        android:text="Commute Ticket"
        android:textAllCaps="false"
        android:textColor="@color/home_title_text"
        android:textSize="20sp" />

    <Button
        android:id="@+id/btnDailyReport"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/home_btn_report"
        android:text="Daily Report"
        android:textAllCaps="false"
        android:textColor="@color/home_title_text"
        android:textSize="20sp" />

    <Button
        android:id="@+id/btnSettings"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:backgroundTint="@color/home_btn_settings"
        android:text="Settings"
        android:textAllCaps="false"
        android:textColor="@color/home_title_text"
        android:textSize="20sp" />

</LinearLayout>
