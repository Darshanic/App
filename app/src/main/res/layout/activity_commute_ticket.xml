<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/surface_background">

        <!-- Top Information Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/commute_division"
                    android:textStyle="bold"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvDivision"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/commute_loading"
                    android:textSize="16sp"
                    android:textColor="@color/text_accent" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/commute_date"
                    android:textStyle="bold"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/commute_loading"
                    android:textSize="16sp"
                    android:textColor="@color/text_accent" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_color"
            android:layout_marginBottom="16dp" />

        <!-- Route Information -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/commute_route_details"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tvRouteNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/commute_route_coming_soon"
                android:textSize="14sp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/tvRouteInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/commute_from_to_select"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_color"
            android:layout_marginBottom="16dp" />

        <!-- Stop Selection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/commute_from_stop"
                android:textStyle="bold"
                android:textSize="14sp"
                android:paddingBottom="8dp" />

            <Spinner
                android:id="@+id/spFromStop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/commute_to_stop"
                android:textStyle="bold"
                android:textSize="14sp"
                android:paddingBottom="8dp" />

            <Spinner
                android:id="@+id/spToStop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_color"
            android:layout_marginBottom="16dp" />

        <!-- Passenger Selection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/commute_passengers"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:paddingBottom="12dp" />

            <!-- Adults -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="12dp">

                <Button
                    android:id="@+id/btnAdultMinus"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="−"
                    android:textSize="20sp"
                    android:backgroundTint="@color/btn_warning" />

                <TextView
                    android:id="@+id/tvAdultCount"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="2"
                    android:text="@string/commute_adults_default"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:background="@color/counter_background" />

                <Button
                    android:id="@+id/btnAdultPlus"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="+"
                    android:textSize="20sp"
                    android:backgroundTint="@color/btn_warning" />
            </LinearLayout>

            <!-- Children -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="12dp">

                <Button
                    android:id="@+id/btnChildMinus"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="−"
                    android:textSize="20sp"
                    android:backgroundTint="@color/btn_success" />

                <TextView
                    android:id="@+id/tvChildCount"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="2"
                    android:text="@string/commute_children_default"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:background="@color/counter_background" />

                <Button
                    android:id="@+id/btnChildPlus"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="+"
                    android:textSize="20sp"
                    android:backgroundTint="@color/btn_success" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/commute_pass_type"
                android:textStyle="bold"
                android:textSize="14sp"
                android:paddingBottom="6dp" />

            <Spinner
                android:id="@+id/spPassType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tvPassRuleHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/commute_pass_hint"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:paddingBottom="12dp" />

            <!-- Luggage -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnLuggageMinus"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="−"
                    android:textSize="20sp"
                    android:backgroundTint="@color/btn_warning" />

                <TextView
                    android:id="@+id/tvLuggageCount"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="2"
                    android:text="@string/commute_luggage_default"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:background="@color/counter_background" />

                <Button
                    android:id="@+id/btnLuggagePlus"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="+"
                    android:textSize="20sp"
                    android:backgroundTint="@color/btn_warning" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_color"
            android:layout_marginBottom="16dp" />

        <!-- Total Fare -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/panel_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/commute_total_fare"
                android:textStyle="bold"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvTotalFare"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/commute_total_default"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_accent"
                android:gravity="end" />
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="@string/commute_reset"
                android:textSize="16sp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/btn_neutral" />

            <Button
                android:id="@+id/btnPrint"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1.5"
                android:text="@string/commute_print"
                android:textSize="16sp"
                android:layout_marginEnd="8dp"
                android:textStyle="bold"
                android:backgroundTint="@color/text_accent"
                android:textColor="@android:color/white" />

            <Button
                android:id="@+id/btnReport"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="@string/commute_report"
                android:textSize="16sp"
                android:backgroundTint="@color/btn_success" />
        </LinearLayout>

        <Button
            android:id="@+id/btnDayClose"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/commute_day_close"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="@color/btn_danger"
            android:textColor="@android:color/white" />

    </LinearLayout>
</ScrollView>
